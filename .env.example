# Marlin V3 Automation - LLM Configuration
# Copy this file to .env and fill in your API key(s).
# Only ONE provider is needed. The system auto-detects which one to use.
# Priority: Claude > OpenAI > Gemini (if multiple keys are set)

# Google Gemini (free tier: 15 req/min)
# Get key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# OpenAI (GPT-4o recommended)
# Get key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Anthropic Claude (Claude Sonnet 4 recommended)
# Get key at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Optional: override the default model for your provider
# Gemini default:   gemini-2.0-flash
# OpenAI default:   gpt-4o
# Claude default:   claude-sonnet-4-20250514
# LLM_MODEL=

# Optional: WSL distro name (default: Ubuntu)
# WSL_DISTRO=Ubuntu

# Optional: GitHub personal access token (avoids 60 req/hr API rate limit)
# Without this, you may hit rate limits when fetching many PRs
# Get token at: https://github.com/settings/tokens (no scopes needed for public repos)
# GITHUB_TOKEN=ghp_...
